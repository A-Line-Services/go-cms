package components

import (
	"encoding/json"
	"strings"
	cms "go.a-line.be/cms"
)

// jsonLDScript wraps a JSON string in a <script type="application/ld+json"> tag.
func jsonLDScript(data string) string {
	return `<script type="application/ld+json">` + data + `</script>`
}

// SchemaWebSite renders a WebSite JSON-LD schema.
templ SchemaWebSite(p cms.PageData) {
	if p.SiteURL() != "" {
		@templ.Raw(jsonLDScript(buildWebSiteSchema(p)))
	}
}

// SchemaLocalBusiness renders a LocalBusiness JSON-LD schema.
templ SchemaLocalBusiness(p cms.PageData) {
	@templ.Raw(jsonLDScript(buildLocalBusinessSchema(p)))
}

// SchemaPerson renders a Person JSON-LD schema for the business owner.
templ SchemaPerson(p cms.PageData) {
	@templ.Raw(jsonLDScript(buildPersonSchema(p)))
}

// SchemaServices renders Service JSON-LD schemas.
templ SchemaServices(p cms.PageData) {
	@templ.Raw(jsonLDScript(buildServicesSchema(p)))
}

// SchemaBreadcrumb renders a BreadcrumbList JSON-LD schema.
templ SchemaBreadcrumb(p cms.PageData) {
	if p.SiteURL() != "" {
		@templ.Raw(jsonLDScript(buildBreadcrumbSchema(p)))
	}
}

// --- JSON builders ---

func buildWebSiteSchema(p cms.PageData) string {
	schema := map[string]any{
		"@context": "https://schema.org",
		"@type":    "WebSite",
		"url":      p.SiteURL() + "/",
	}
	if p.SiteName() != "" {
		schema["name"] = p.SiteName()
	}
	b, _ := json.Marshal(schema)
	return string(b)
}

func buildLocalBusinessSchema(p cms.PageData) string {
	c := p.SEOConfig()
	schema := map[string]any{
		"@context": "https://schema.org",
		"@type":    c.BusinessType,
		"name":     c.BusinessName,
	}
	if p.SiteURL() != "" {
		schema["url"] = p.SiteURL() + "/"
	}
	if c.Phone != "" {
		schema["telephone"] = c.Phone
	}
	if c.Email != "" {
		schema["email"] = c.Email
	}
	if c.PriceRange != "" {
		schema["priceRange"] = c.PriceRange
	}
	if c.FoundingDate != "" {
		schema["foundingDate"] = c.FoundingDate
	}
	if c.VatID != "" {
		schema["vatID"] = c.VatID
	}

	// Address
	if c.StreetAddress != "" || c.AddressLocality != "" {
		addr := map[string]any{
			"@type": "PostalAddress",
		}
		if c.StreetAddress != "" {
			addr["streetAddress"] = c.StreetAddress
		}
		if c.AddressLocality != "" {
			addr["addressLocality"] = c.AddressLocality
		}
		if c.AddressRegion != "" {
			addr["addressRegion"] = c.AddressRegion
		}
		if c.PostalCode != "" {
			addr["postalCode"] = c.PostalCode
		}
		if c.AddressCountry != "" {
			addr["addressCountry"] = c.AddressCountry
		}
		schema["address"] = addr
	}

	// Geo coordinates
	if c.GeoLat != nil && c.GeoLng != nil {
		schema["geo"] = map[string]any{
			"@type":     "GeoCoordinates",
			"latitude":  *c.GeoLat,
			"longitude": *c.GeoLng,
		}
	}

	// Service areas
	if len(c.ServiceAreas) > 0 {
		areas := make([]map[string]any, len(c.ServiceAreas))
		for i, area := range c.ServiceAreas {
			areas[i] = map[string]any{
				"@type": "GeoCircle",
				"geoMidpoint": map[string]any{
					"@type": "GeoCoordinates",
					"name":  area,
				},
			}
		}
		schema["areaServed"] = areas
	}

	// Opening hours
	if len(c.OpeningHours) > 0 {
		var specs []map[string]any
		for _, oh := range c.OpeningHours {
			if oh.Days == "" {
				continue
			}
			spec := map[string]any{
				"@type":     "OpeningHoursSpecification",
				"dayOfWeek": strings.Split(oh.Days, ","),
			}
			if oh.Opens != "" {
				spec["opens"] = oh.Opens
			}
			if oh.Closes != "" {
				spec["closes"] = oh.Closes
			}
			specs = append(specs, spec)
		}
		if len(specs) > 0 {
			schema["openingHoursSpecification"] = specs
		}
	}

	// Social profiles
	if len(c.SocialProfiles) > 0 {
		schema["sameAs"] = c.SocialProfiles
	}

	// Default image
	if c.DefaultOGImageURL != "" {
		schema["image"] = c.DefaultOGImageURL
	}

	b, _ := json.Marshal(schema)
	return string(b)
}

func buildPersonSchema(p cms.PageData) string {
	c := p.SEOConfig()
	schema := map[string]any{
		"@context": "https://schema.org",
		"@type":    "Person",
		"name":     c.OwnerName,
	}
	if c.OwnerJobTitle != "" {
		schema["jobTitle"] = c.OwnerJobTitle
	}
	if c.OwnerDescription != "" {
		schema["description"] = c.OwnerDescription
	}
	if c.OwnerImageURL != "" {
		schema["image"] = c.OwnerImageURL
	}
	if p.SiteURL() != "" {
		schema["url"] = p.SiteURL() + "/"
	}
	if len(c.OwnerSameAs) > 0 {
		schema["sameAs"] = c.OwnerSameAs
	}
	// Link to the business
	if c.BusinessName != "" {
		schema["worksFor"] = map[string]any{
			"@type": c.BusinessType,
			"name":  c.BusinessName,
		}
	}
	b, _ := json.Marshal(schema)
	return string(b)
}

func buildServicesSchema(p cms.PageData) string {
	c := p.SEOConfig()
	var services []map[string]any
	for _, svc := range c.Services {
		if svc.Name == "" {
			continue
		}
		s := map[string]any{
			"@type": "Service",
			"name":  svc.Name,
		}
		if svc.Description != "" {
			s["description"] = svc.Description
		}
		if c.BusinessName != "" {
			s["provider"] = map[string]any{
				"@type": c.BusinessType,
				"name":  c.BusinessName,
			}
		}
		if len(c.ServiceAreas) > 0 {
			s["areaServed"] = c.ServiceAreas
		}
		services = append(services, s)
	}
	wrapper := map[string]any{
		"@context": "https://schema.org",
		"@graph":   services,
	}
	b, _ := json.Marshal(wrapper)
	return string(b)
}

func buildBreadcrumbSchema(p cms.PageData) string {
	siteURL := p.SiteURL()
	path := p.ContentPath()

	items := []map[string]any{
		{
			"@type":    "ListItem",
			"position": 1,
			"name":     "Home",
			"item":     siteURL + "/",
		},
	}

	if path != "/" {
		parts := strings.Split(strings.Trim(path, "/"), "/")
		for i, part := range parts {
			// Build URL up to this segment
			segPath := "/" + strings.Join(parts[:i+1], "/") + "/"
			items = append(items, map[string]any{
				"@type":    "ListItem",
				"position": i + 2,
				"name":     strings.Title(strings.ReplaceAll(part, "-", " ")),
				"item":     siteURL + segPath,
			})
		}
	}

	schema := map[string]any{
		"@context":        "https://schema.org",
		"@type":           "BreadcrumbList",
		"itemListElement": items,
	}
	b, _ := json.Marshal(schema)
	return string(b)
}
